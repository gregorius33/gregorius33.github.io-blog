---
import Layout from '../layouts/Layout.astro';
import { siteConfig } from '../site-config';

const { siteName, aboutContent } = siteConfig;
---

<Layout title={`About - ${siteName}`} description="블로그 소개 페이지입니다.">
  <div class="max-w-4xl mx-auto px-4 py-12">
    <h1 class="text-4xl font-bold text-slate-800 mb-6">About</h1>
    <div class="prose prose-slate max-w-none" set:html={aboutContent} />
  </div>
</Layout>
