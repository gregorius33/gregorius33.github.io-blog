---
import Layout from '../layouts/Layout.astro';
import BlogCard from '../components/BlogCard.astro';
import { getCollection } from 'astro:content';
import { siteConfig } from '../site-config';

const base = import.meta.env.BASE_URL;
const { homeGreeting, homeSubtitle, homeImage, siteName } = siteConfig;
const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 5);

const isHomeImageEmoji = !/\.(jpg|jpeg|png|gif|webp|svg)$/i.test(homeImage) && !homeImage.startsWith('http');
---

<Layout title={`${siteName} - Home`} description="개인 블로그에 오신 것을 환영합니다.">
  <div class="max-w-4xl mx-auto px-4 py-12">
    <section class="mb-16 py-8 px-6 rounded-2xl bg-gradient-to-br from-slate-100 to-slate-50 border border-slate-100 flex flex-col md:flex-row items-center gap-8">
      {isHomeImageEmoji ? (
        <span class="text-6xl md:text-8xl shrink-0">{homeImage}</span>
      ) : (
        <img
          src={`${base}${homeImage}`}
          alt="블로그 대표 아이콘"
          class="w-24 h-24 md:w-32 md:h-32 rounded-full object-cover ring-4 ring-white shadow-lg shrink-0"
        />
      )}
      <div>
        <h1 class="text-4xl md:text-5xl font-bold text-slate-800 mb-4">
          {homeGreeting}
        </h1>
        <p class="text-lg md:text-xl text-slate-600 leading-relaxed max-w-2xl whitespace-pre-line">
          {homeSubtitle}
        </p>
      </div>
    </section>

    <section>
      <h2 class="text-2xl font-semibold text-slate-800 mb-6">최신 포스트</h2>
      <div class="grid gap-6 md:grid-cols-2">
        {posts.map((entry) => (
          <BlogCard entry={entry} />
        ))}
      </div>
      {posts.length === 0 && (
        <p class="text-slate-500">아직 작성된 포스트가 없습니다.</p>
      )}
    </section>
  </div>
</Layout>
