---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { siteConfig } from '../site-config';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = '개인 블로그입니다.' } = Astro.props;
const base = import.meta.env.BASE_URL;
const { favicon } = siteConfig;
const faviconType = favicon.endsWith('.png') ? 'image/png' : favicon.endsWith('.ico') ? 'image/x-icon' : 'image/jpeg';
---

<!DOCTYPE html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" href={`${base}${favicon}`} type={faviconType} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Noto+Sans+KR:wght@400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body class="min-h-screen bg-slate-50 text-slate-800 font-sans antialiased flex flex-col">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
