---
const base = import.meta.env.BASE_URL;
---

<header class="border-b border-slate-200 bg-white/95 backdrop-blur-sm sticky top-0 z-50 shadow-sm">
  <nav class="max-w-4xl mx-auto px-4 py-4 flex items-center justify-between">
    <a href={base} class="text-xl font-bold text-slate-800 hover:text-slate-600 transition-colors">
      Greg's My Blog
    </a>
    <ul class="flex gap-4 md:gap-6 text-sm md:text-base">
      <li>
        <a href={base} class="text-slate-600 hover:text-slate-900 font-medium transition-colors">Home</a>
      </li>
      <li>
        <a href={`${base}about/`} class="text-slate-600 hover:text-slate-900 font-medium transition-colors">About</a>
      </li>
      <li>
        <a href={`${base}blog/`} class="text-slate-600 hover:text-slate-900 font-medium transition-colors">Blog</a>
      </li>
    </ul>
  </nav>
</header>
