---
const base = import.meta.env.BASE_URL;
const year = new Date().getFullYear();
---

<footer class="border-t border-slate-200 bg-white mt-auto">
  <div class="max-w-4xl mx-auto px-4 py-8">
    <div class="flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-slate-500 text-sm">
        © {year} My Blog. All rights reserved.
      </p>
      <ul class="flex gap-6">
        <li>
          <a href={base} class="text-slate-500 hover:text-slate-700 text-sm transition-colors">Home</a>
        </li>
        <li>
          <a href={`${base}about/`} class="text-slate-500 hover:text-slate-700 text-sm transition-colors">About</a>
        </li>
        <li>
          <a href={`${base}blog/`} class="text-slate-500 hover:text-slate-700 text-sm transition-colors">Blog</a>
        </li>
      </ul>
    </div>
  </div>
</footer>
